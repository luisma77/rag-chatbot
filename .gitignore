# ── Private documents & embeddings (NEVER commit) ────────────────────────────
data/documents/
chroma_db/

# Keep directory structure but not contents
!data/documents/.gitkeep
!chroma_db/.gitkeep

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
ENV/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ── Temporary / test files ────────────────────────────────────────────────────
*.tmp
*.bak
