# ── Identidad del despliegue ────────────────────────────────────────────────
SYSTEM_PROFILE=medio
LLM_PROFILE=balanced
INGESTION_PRESET=balanced
PDF_PIPELINE=balanced
OCR_BACKEND=tesseract

# ── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=20m
OLLAMA_NUM_PREDICT=384
OLLAMA_TEMPERATURE_RAG=0.1
OLLAMA_TEMPERATURE_CHAT=0.6

# ── Embeddings ──────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_PROFILE=balanced
EMBEDDING_BATCH_SIZE=32

# ── Vector DB y documentos ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=documents
DOCUMENTS_DIR=./data/documents

# ── Recuperación y cache ────────────────────────────────────────────────────
TOP_K=5
SIMILARITY_THRESHOLD=0.58
CACHE_THRESHOLD=0.74
CACHE_TTL_SECONDS=7200

# ── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MAX_CONCURRENT_LLM=2
API_KEY=
ALLOWED_ORIGINS=*

# ── Chunking ────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── OCR ─────────────────────────────────────────────────────────────────────
TESSERACT_LANG=spa+eng

# ── Instalación / logging ───────────────────────────────────────────────────
PROMPT_FOR_UPDATES=true
INSTALL_QUALITY_EXTRAS=false
USE_GPU=false
GPU_BACKEND=none
LOG_LEVEL=INFO
LOG_DIR=./logs
