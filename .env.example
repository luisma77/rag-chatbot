# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=20m
OLLAMA_NUM_PREDICT=384
OLLAMA_TEMPERATURE_RAG=0.1
OLLAMA_TEMPERATURE_CHAT=0.6
SYSTEM_PROFILE=medio
LLM_PROFILE=balanced
USE_GPU=false
GPU_BACKEND=none

# Embeddings
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_PROFILE=balanced
EMBEDDING_BATCH_SIZE=32

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=documents

# Documents
DOCUMENTS_DIR=./data/documents

# RAG tuning
TOP_K=5
SIMILARITY_THRESHOLD=0.65
CACHE_THRESHOLD=0.75
CACHE_TTL_SECONDS=7200

# API
API_HOST=0.0.0.0
API_PORT=8000
MAX_CONCURRENT_LLM=3

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100
INGESTION_PRESET=balanced
PDF_PIPELINE=balanced

# Tesseract / Poppler
TESSERACT_CMD=tesseract
TESSERACT_LANG=spa+eng
OCR_BACKEND=tesseract
POPPLER_PATH=

# Installation behavior
PROMPT_FOR_UPDATES=true
INSTALL_QUALITY_EXTRAS=false

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
